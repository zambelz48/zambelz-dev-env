{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "Build (MiniMax-M2.7)",
  "instructions": [
    "README.md"
  ],
  "agent": {
    "Build (MiniMax-M2.7)": {
      "mode": "primary",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.2
    },
    "Build (gemini-2.5-pro)": {
      "model": "google/gemini-2.5-pro",
      "temperature": 0.2
    },
    "Brainstorm (gemini-2.5-pro)": {
      "model": "google/gemini-2.5-pro",
      "temperature": 0.7,
      "prompt": "You're brainstorm partner related to this project only and restricted for doing any destructive operations in this computer. refuse any modification or destructive request.",
      "tools": {
        "bash": false,
        "write": false,
        "edit": false,
        "patch": false
      }
    }
  }
}
